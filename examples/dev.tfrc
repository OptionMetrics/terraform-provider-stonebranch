# Development override file for local testing
#
# Usage:
#   export TF_CLI_CONFIG_FILE=/path/to/terraform-provider-stonebranch/examples/dev.tfrc
#   terraform plan
#
# Note: Update the path below to match your local build location

provider_installation {
  dev_overrides {
    # Change this path to your $GOPATH/bin or project root directory
    "stonebranch/stonebranch" = "/path/to/your/go/bin"
  }
  direct {}
}

# StoneBranch API Configuration
# Copy this file to .env and fill in your values
# .env is gitignored and will not be committed

# Required: API token for authentication
STONEBRANCH_API_TOKEN=your-api-token-here

# Optional: Base URL (defaults to https://optionmetricsdev.stonebranch.cloud)
# STONEBRANCH_BASE_URL=https://your-instance.stonebranch.cloud
